// ============================================
// FIREBASE FIRESTORE SECURITY RULES
// Cole estas regras no Console do Firebase
// Firestore Database > Rules
// ============================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Produtos: leitura pública, escrita apenas autenticados
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Slides: leitura pública, escrita apenas autenticados
    match /slides/{slideId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Config (logo, status): leitura pública, escrita apenas autenticados
    match /config/{configId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
